[
  {
    "category": "effect",
    "name": "Damage/Heal/Repair",
    "since": "1.0, 2.10 (damage cause)",
    "patterns": [
      "damage %livingentities/itemtypes/slots% by %number% [heart[s]]",
      "damage %livingentities% by %number% [heart[s]] with [fake] [damage] cause %damagecause%",
      "damage %livingentities% by %number% [heart[s]] (using|with) %damagesource% [as the source]",
      "heal %livingentities% [by %-number% [heart[s]]]",
      "repair %itemtypes/slots% [by %-number%]"
    ],
    "source": "ch/njol/skript/effects/EffHealth.java"
  },
  {
    "category": "effect",
    "name": "Hide Player from Server List",
    "since": "2.3",
    "patterns": [
      "hide %players% (in|on|from) [the] server list",
      "hide %players%'[s] info[rmation] (in|on|from) [the] server list"
    ],
    "source": "ch/njol/skript/effects/EffHidePlayerFromServerList.java"
  },
  {
    "category": "effect",
    "name": "Ignite/Extinguish",
    "since": "1.4",
    "patterns": [
      "(ignite|set fire to) %entities% [for %-timespan%]",
      "(set|light) %entities% on fire [for %-timespan%]",
      "extinguish %entities%"
    ],
    "source": "ch/njol/skript/effects/EffIgnite.java"
  },
  {
    "category": "effect",
    "name": "Make Incendiary",
    "since": "2.5",
    "patterns": [
      "make %entities% [(1¦not)] incendiary",
      "make %entities%'[s] explosion [(1¦not)] (incendiary|fiery)",
      "make [the] [event(-| )]explosion [(1¦not)] (incendiary|fiery)"
    ],
    "source": "ch/njol/skript/effects/EffIncendiary.java"
  },
  {
    "category": "effect",
    "name": "Insert Entity Storage",
    "since": "2.11",
    "patterns": [
      "(add|insert) %livingentities% [in[ ]]to [the] (stored entities|entity storage) of %block%"
    ],
    "source": "ch/njol/skript/effects/EffInsertEntityStorage.java"
  },
  {
    "category": "effect",
    "name": "Make Invisible",
    "since": "2.7",
    "patterns": [
      "make %livingentities% (invisible|not visible)",
      "make %livingentities% (visible|not invisible)"
    ],
    "source": "ch/njol/skript/effects/EffInvisible.java"
  },
  {
    "category": "effect",
    "name": "Make Invulnerable",
    "since": "2.5",
    "patterns": [
      "make %entities% (invulnerable|invincible)",
      "make %entities% (not (invulnerable|invincible)|vulnerable|vincible)"
    ],
    "source": "ch/njol/skript/effects/EffInvulnerability.java"
  },
  {
    "category": "effect",
    "name": "Item Despawn",
    "since": "2.11",
    "patterns": [
      "(prevent|disallow) %itementities% from (naturally despawning|despawning naturally)",
      "allow natural despawning of %itementities%",
      "allow %itementities% to (naturally despawn|despawn naturally)"
    ],
    "source": "ch/njol/skript/effects/EffItemDespawn.java"
  },
  {
    "category": "effect",
    "name": "Keep Inventory / Experience",
    "since": "2.4",
    "patterns": [
      "keep [the] (inventory|items) [(1:and [e]xp[erience][s] [point[s]])]",
      "keep [the] [e]xp[erience][s] [point[s]] [(1:and (inventory|items))]"
    ],
    "source": "ch/njol/skript/effects/EffKeepInventory.java"
  },
  {
    "category": "effect",
    "name": "Kill",
    "since": "1.0, 2.10 (ignoring totem of undying)",
    "patterns": [
      "kill %entities%"
    ],
    "source": "ch/njol/skript/effects/EffKill.java"
  },
  {
    "category": "effect",
    "name": "Knockback",
    "since": "2.7",
    "patterns": [
      "(apply knockback to|knock[back]) %livingentities% [%direction%] [with (strength|force) %-number%]"
    ],
    "source": "ch/njol/skript/effects/EffKnockback.java"
  },
  {
    "category": "effect",
    "name": "Leash entities",
    "since": "2.3",
    "patterns": [
      "(leash|lead) %livingentities% to %entity%",
      "make %entity% (leash|lead) %livingentities%",
      "un(leash|lead) [holder of] %livingentities%"
    ],
    "source": "ch/njol/skript/effects/EffLeash.java"
  },
  {
    "category": "effect",
    "name": "Open/Close Lid",
    "since": "2.10",
    "patterns": [
      "(open|:close) [the] lid[s] (of|for) %blocks%",
      "(open|:close) %blocks%'[s] lid[s]"
    ],
    "source": "ch/njol/skript/effects/EffLidState.java"
  },
  {
    "category": "effect",
    "name": "Lightning",
    "since": "1.4",
    "patterns": [
      "(create|strike) lightning(1¦[ ]effect|) %directions% %locations%"
    ],
    "source": "ch/njol/skript/effects/EffLightning.java"
  }
]
