[
  {
    "category": "condition",
    "name": "Has Permission",
    "since": "1.0",
    "patterns": [
      "%commandsenders% (has|have) [the] permission[s] %strings%",
      "%commandsenders% (doesn't|does not|do not|don't) have [the] permission[s] %strings%"
    ],
    "source": "ch/njol/skript/conditions/CondPermission.java"
  },
  {
    "category": "condition",
    "name": "Has Played Before",
    "since": "1.4, 2.7 (multiple players)",
    "patterns": [
      "%offlineplayers% [(has|have|did)] [already] play[ed] [on (this|the) server] (before|already)",
      "%offlineplayers% (has not|hasn't|have not|haven't|did not|didn't) [(already|yet)] play[ed] [on (this|the) server] (before|already|yet)"
    ],
    "source": "ch/njol/skript/conditions/CondPlayedBefore.java"
  },
  {
    "category": "condition",
    "name": "PvP",
    "since": "1.3.4",
    "patterns": [
      "(is PvP|PvP is) enabled [in %worlds%]",
      "(is PvP|PvP is) disabled [in %worlds%]"
    ],
    "source": "ch/njol/skript/conditions/CondPvP.java"
  },
  {
    "category": "condition",
    "name": "Resource Pack",
    "since": "2.4",
    "patterns": [
      "[the] resource pack (was|is|has) [been] %resourcepackstate%",
      "[the] resource pack (was|is|has)(n't| not) [been] %resourcepackstate%"
    ],
    "source": "ch/njol/skript/conditions/CondResourcePack.java"
  },
  {
    "category": "condition",
    "name": "Is Bed/Anchor Spawn",
    "since": "2.7",
    "patterns": [
      "[the] respawn location (was|is)[1:(n'| no)t] [a] (:bed|respawn anchor)"
    ],
    "source": "ch/njol/skript/conditions/CondRespawnLocation.java"
  },
  {
    "category": "condition",
    "name": "Is Script Loaded",
    "since": "2.2-dev31",
    "patterns": [
      "script[s] [%-strings%] (is|are) loaded",
      "script[s] [%-strings%] (isn't|is not|aren't|are not) loaded"
    ],
    "source": "ch/njol/skript/conditions/CondScriptLoaded.java"
  },
  {
    "category": "condition",
    "name": "Starts/Ends With",
    "since": "2.2-dev36, 2.5.1 (multiple strings support)",
    "patterns": [
      "%strings% (start|1¦end)[s] with %strings%",
      "%strings% (doesn't|does not|do not|don't) (start|1¦end) with %strings%"
    ],
    "source": "ch/njol/skript/conditions/CondStartsEndsWith.java"
  },
  {
    "category": "condition",
    "name": "Strider Is Shivering",
    "since": "2.12",
    "patterns": [
      "%livingentities% (is|are) shivering",
      "%livingentities% (isn't|aren't|is not|are not) shivering"
    ],
    "source": "ch/njol/skript/conditions/CondStriderIsShivering.java"
  },
  {
    "category": "condition",
    "name": "Has Item Tooltips",
    "since": "2.9.0",
    "patterns": [
      "[the] [entire|:additional] tool[ ]tip[s] of %itemtypes% (is|are) (:shown|hidden)",
      "[the] [entire|:additional] tool[ ]tip[s] of %itemtypes% (isn't|is not|aren't|are not) (:shown|hidden)",
      "%itemtypes%'[s] [entire|:additional] tool[ ]tip[s] (is|are) (:shown|hidden)",
      "%itemtypes%'[s] [entire|:additional] tool[ ]tip[s] (isn't|is not|aren't|are not) (:shown|hidden)"
    ],
    "source": "ch/njol/skript/conditions/CondTooltip.java"
  },
  {
    "category": "condition",
    "name": "Egg Will Hatch",
    "since": "2.7",
    "patterns": [
      "[the] egg (:will|will not|won't) hatch"
    ],
    "source": "ch/njol/skript/conditions/CondWillHatch.java"
  },
  {
    "category": "condition",
    "name": "Is Within Radius",
    "since": "2.7",
    "patterns": [
      "%locations% (is|are) within %number% (block|metre|meter)[s] (around|of) %locations%",
      "%locations% (isn't|aren't|is not|are not) within %number% (block|metre|meter)[s] (around|of) %locations%"
    ],
    "source": "ch/njol/skript/conditions/CondWithinRadius.java"
  },
  {
    "category": "effect",
    "name": "Delay",
    "since": "1.4",
    "patterns": [
      "(wait|halt) [for] %timespan%"
    ],
    "source": "ch/njol/skript/effects/Delay.java"
  },
  {
    "category": "effect",
    "name": "Allay Duplicate",
    "since": "2.11",
    "patterns": [
      "allow %livingentities% to (duplicate|clone)",
      "prevent %livingentities% from (duplicating|cloning)"
    ],
    "source": "ch/njol/skript/effects/EffAllayCanDuplicate.java"
  },
  {
    "category": "effect",
    "name": "Make Allay Duplicate",
    "since": "2.11",
    "patterns": [
      "make %livingentities% (duplicate|clone)"
    ],
    "source": "ch/njol/skript/effects/EffAllayDuplicate.java"
  }
]
